{
  "name": "nexus-mod-manager",
  "version": "3.0.1",
  "description": "通用 Nexus Mods 管理器",
  "license": "MIT",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/index.css -o ./dist-tauri/output.css --watch",
    "build:tauri-fe": "npx tailwindcss -i ./src/index.css -o ./dist-tauri/output.css && webpack --config webpack.tauri.config.js --mode production",
    "tauri": "npx tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "@tauri-apps/cli": "^2.10.1",
    "autoprefixer": "^10.4.18",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
